# =========================================
# DATABASE
# =========================================
DATABASE_URL="postgresql://target_user:secret_password@localhost:5432/target_bot?schema=public"

# =========================================
# META (FACEBOOK) MARKETING API
# =========================================
# Long-lived yoki System User token (Business Manager → System Users → Generate Token)
# Scopes kerak: ads_read, ads_management, leads_retrieval, business_management
META_ACCESS_TOKEN="EAAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
META_APP_ID="1234567890123456"
META_APP_SECRET="abcdef1234567890abcdef1234567890"
META_AD_ACCOUNT_ID="act_1216437396501920"
META_API_VERSION="v21.0"

# Campaign IDs (URL dagi selected_campaign_ids)
META_CAMPAIGN_1_ID="120241992527790658"
META_CAMPAIGN_2_ID="120241994776580658"

# =========================================
# TELEGRAM BOT
# =========================================
# @BotFather dan oling
TELEGRAM_BOT_TOKEN="123456789:ABCdefGhIJKlmNOpQRsTUvWXyZ"
# Guruh chat ID (manfiy raqam, masalan -1001234567890)
TELEGRAM_CHAT_ID="-1001234567890"
# Optional: Telegram topic ID (agar guruh forum bo'lsa)
TELEGRAM_THREAD_ID=""
# Admin user ID (xato xabarlarini olish uchun, optional)
TELEGRAM_ADMIN_ID=""

# Admin paroli — /admin <parol> orqali ro'yxatdan o'tish uchun
ADMIN_PASSWORD="change-me-strong-password"

# =========================================
# APPLICATION
# =========================================
NODE_ENV="production"
LOG_LEVEL="info"
TZ="Asia/Tashkent"
# Cron expression: kuniga 08:00 — "0 8 * * *"
CRON_SCHEDULE="0 8 * * *"
# Token health check cron — har kuni soat 09:00
TOKEN_CHECK_SCHEDULE="0 9 * * *"

# =========================================
# CURRENCY & FORMATTING
# =========================================
CURRENCY="UZS"
CURRENCY_LABEL="so'm"

# =========================================
# GOOGLE SHEETS (Apps Script Webhook)
# =========================================
# Sheets'da Extensions → Apps Script → APPS_SCRIPT_CODE.gs paste → Deploy → URL
SHEETS_WEBHOOK_URL=""
SHEETS_WEBHOOK_SECRET="change-me-strong-secret"

# =========================================
# OPTIONAL — MONITORING
# =========================================
SENTRY_DSN=""
